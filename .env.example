# PhoneTracker Advanced - API Keys (all optional, enhance results)
# Copy this file to .env and fill in your keys

# NumVerify API - carrier, line type, location data
# Get free key at: https://numverify.com
NUMVERIFY_API_KEY=

# AbstractAPI Phone Validation - spam score, line type
# Get free key at: https://app.abstractapi.com
ABSTRACT_API_KEY=

# IPGeolocation API - enhanced timezone data
# Get free key at: https://ipgeolocation.io
IPGEO_API_KEY=

# Twilio (for authoritative carrier lookup)
# https://www.twilio.com/lookup
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Cache settings (seconds)
CACHE_TTL=3600

# Default output format: pretty | json | table | csv | minimal
DEFAULT_FORMAT=pretty

# History file location (leave blank for default ~/.phonetracker/history.json)
HISTORY_FILE=
